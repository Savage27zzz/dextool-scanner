# ──────────────────────────────────────
# Telegram Configuration
# ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ──────────────────────────────────────
# Wallet Configuration
# ──────────────────────────────────────
# Base58-encoded Solana private key, or JSON byte array [1,2,3,...]
PRIVATE_KEY=your_base58_private_key

# ──────────────────────────────────────
# Encryption (required for multi-user wallet storage)
# ──────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ──────────────────────────────────────
# RPC Endpoints
# ──────────────────────────────────────
# Solana (primary) — use Helius/QuickNode for better reliability
RPC_URL_SOL=https://api.mainnet-beta.solana.com

# EVM chains (optional, only needed if CHAIN=ETH or CHAIN=BSC)
RPC_URL_ETH=https://mainnet.infura.io/v3/YOUR_KEY
RPC_URL_BSC=https://bsc-dataseed1.binance.org

# ──────────────────────────────────────
# DexTools API (optional — bot works without it using DexScreener only)
# ──────────────────────────────────────
# Get a key at https://developer.dextools.io (paid plans only)
# Leave empty to use DexScreener-only mode
DEXTOOLS_API_KEY=
DEXTOOLS_PLAN=trial

# ──────────────────────────────────────
# Chain Selection
# ──────────────────────────────────────
# SOL (default) | ETH | BSC
CHAIN=SOL

# ──────────────────────────────────────
# Trading Configuration
# ──────────────────────────────────────
BUY_PERCENT=50
TAKE_PROFIT=20
STOP_LOSS=-30         # % ROI to trigger auto-sell (negative number)
TRAILING_ENABLED=true # Enable trailing take-profit (true/false)
TRAILING_DROP=10      # % drop from peak to trigger sell
SLIPPAGE=15

# Tiered Sells (ROI%:SELL%, comma-separated). Empty = single sell at TAKE_PROFIT
SELL_TIERS=50:50,100:25

# ──────────────────────────────────────
# Filter Configuration
# ──────────────────────────────────────
MIN_LIQUIDITY=5000
MAX_MCAP=500000
MIN_MCAP=10000

# ──────────────────────────────────────
# Intervals (seconds)
# ──────────────────────────────────────
SCAN_INTERVAL=60
MONITOR_INTERVAL=30
MIN_SCORE=40          # Minimum safety score (0-100) to auto-buy

# ──────────────────────────────────────
# Whale Tracking
# ──────────────────────────────────────
WHALE_TRACKING_ENABLED=true
WHALE_CHECK_INTERVAL=45     # Seconds between wallet checks
WHALE_MIN_SOL=1.0           # Minimum SOL spent to trigger alert

# ──────────────────────────────────────
# Whale Copy Trading
# ──────────────────────────────────────
WHALE_COPY_ENABLED=false
WHALE_COPY_AMOUNT=0.1
WHALE_COPY_MAX_PER_TOKEN=1

# ──────────────────────────────────────
# Anti-Rug Protection
# ──────────────────────────────────────
ANTIRUG_ENABLED=true
ANTIRUG_MIN_LIQ=1000        # Emergency sell if liquidity drops below this USD amount
ANTIRUG_LIQ_DROP_PCT=70     # Emergency sell if liquidity drops by this % from entry

# ──────────────────────────────────────
# Operator Fee (% of profits)
# ──────────────────────────────────────
OPERATOR_FEE_ENABLED=true
OPERATOR_FEE_PCT=5             # 5% of profit on each winning trade

# ──────────────────────────────────────
# Risk Management
# ──────────────────────────────────────
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS=2.0
MAX_BUY_AMOUNT=1.0

# ──────────────────────────────────────
# External API
# ──────────────────────────────────────
API_ENABLED=false
API_PORT=8080
API_KEY=your-secret-api-key-here
